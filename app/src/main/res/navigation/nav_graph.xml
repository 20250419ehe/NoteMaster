<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/noteListFragment">

    <fragment
        android:id="@+id/noteListFragment"
        android:name="com.example.notemaster.ui.note.NoteListFragment"
        android:label="笔记列表"
        tools:layout="@layout/fragment_note_list">

        <action
            android:id="@+id/action_noteList_to_noteEdit"
            app:destination="@id/noteEditFragment"
            app:popUpTo="@id/noteListFragment"
            app:popUpToInclusive="false" />

        <action
            android:id="@+id/action_noteList_to_search"
            app:destination="@id/searchFragment"
            app:popUpTo="@id/noteListFragment"
            app:popUpToInclusive="false" />

        <action
            android:id="@+id/action_noteList_to_categoryList"
            app:destination="@id/categoryListFragment"
            app:popUpTo="@id/noteListFragment"
            app:popUpToInclusive="false" />

        <action
            android:id="@+id/action_noteList_to_settings"
            app:destination="@id/settingsFragment"
            app:popUpTo="@id/noteListFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <fragment
        android:id="@+id/noteEditFragment"
        android:name="com.example.notemaster.ui.note.NoteEditFragment"
        android:label="编辑笔记"
        tools:layout="@layout/fragment_note_edit">

        <argument
            android:name="noteId"
            app:argType="long"
            android:defaultValue="-1" />

        <action
            android:id="@+id/action_noteEdit_to_noteList"
            app:destination="@id/noteListFragment"
            app:popUpTo="@id/noteListFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/categoryListFragment"
        android:name="com.example.notemaster.ui.category.CategoryListFragment"
        android:label="分类管理"
        tools:layout="@layout/fragment_category_list">

        <action
            android:id="@+id/action_categoryList_to_noteList"
            app:destination="@id/noteListFragment"
            app:popUpTo="@id/noteListFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.notemaster.ui.search.SearchFragment"
        android:label="搜索"
        tools:layout="@layout/fragment_search">

        <action
            android:id="@+id/action_search_to_noteEdit"
            app:destination="@id/noteEditFragment"
            app:popUpTo="@id/searchFragment"
            app:popUpToInclusive="false" />

        <action
            android:id="@+id/action_search_to_noteList"
            app:destination="@id/noteListFragment"
            app:popUpTo="@id/noteListFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.notemaster.ui.settings.SettingsFragment"
        android:label="设置"
        tools:layout="@layout/fragment_settings">

        <action
            android:id="@+id/action_settings_to_noteList"
            app:destination="@id/noteListFragment"
            app:popUpTo="@id/noteListFragment"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>